      "pathPrefixes": [
        "backend/tools/diarization/",
        "tools/diarization/"
      ]
    },
    {
      "id": "backend-executable",
      "backendExecutable": true
    },
    {
      "id": "backend-first-party",
      "pathPrefixes": ["backend/app/", "app/"]
    },
    {
      "id": "js-runtime",
      "exactPaths": [
        "backend/tools/ffmpeg/deno.exe",
        "backend/tools/ffmpeg/qjs.exe",
