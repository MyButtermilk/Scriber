{
  "schemaVersion": 1,
  "mapId": "installer-component-map-v1",
  "pyinstallerVersion": "6.20.0",
  "classificationPolicy": "all-explicit-matches-or-fallback",
  "fallbackComponent": "other-payload",
  "components": [
