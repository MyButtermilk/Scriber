  "semanticNormalization": {
    "sidecarMetadataFileNames": ["sidecar-build-metadata.json"],
    "tauriBundleTypeMarker": {
      "desktopExecutablePath": "scriber-desktop.exe",
      "prefix": "__TAURI_BUNDLE_TYPE_VAR_",
      "allowedValues": ["UNK", "NSS"],
      "normalizedValue": "UNK"
    },
    "contract": "scriber-installer-semantic-normalization-v2"
  }
