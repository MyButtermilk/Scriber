  "pyzPrefixComponents": [
    {"prefix": "backend_runtime", "component": "backend-executable"},
    {"prefix": "yt_dlp_ejs", "component": "yt-dlp-ejs"},
    {"prefix": "yt_dlp", "component": "yt-dlp-ejs"},
    {"prefix": "nltk", "component": "nltk-code"},
    {"prefix": "huggingface_hub", "component": "hugging-face"},
    {"prefix": "hf_xet", "component": "hugging-face"},
